# Copy to .env and edit as needed. All variables are optional for the MVP
# (the mock provider needs no keys). Prefix every variable with MUSICGEN_.

# Default provider used when the request does not specify one.
# One of: mock | mubert | local_loop | stable_audio
MUSICGEN_DEFAULT_PROVIDER=mock

# CORS origins allowed to call the API (JSON array).
# MUSICGEN_CORS_ORIGINS=["http://localhost:3000"]

# --- Provider credentials (only needed once you implement real providers) ---
# MUSICGEN_MUBERT_API_KEY=
# MUSICGEN_STABLE_AUDIO_API_KEY=
# MUSICGEN_LOCAL_LOOP_LIBRARY_DIR=./storage/loops
